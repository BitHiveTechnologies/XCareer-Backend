# Server Configuration
NODE_ENV=production
PORT=5000

# Database Configuration
# For Railway, use the provided MongoDB URL or your external URI
MONGODB_URI=mongodb://localhost:27017/careerx


# Frontend URL (CORS)
# Use your actual frontend production URL here
FRONTEND_URL=https://careerx-website.vercel.app

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# Payment Configuration (Razorpay / Cashfree)
# We have migrated to Cashfree for guest checkouts
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
CASHFREE_ENVIRONMENT=SANDBOX

# Logging
LOG_LEVEL=info

# Security
BCRYPT_ROUNDS=12

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/